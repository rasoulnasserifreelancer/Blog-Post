            <article>
                <div>
                    <h3><%= post.title %></h3>
                    <p>By <%= post.fullName %></p>
                    <p><%= post.summary %></p>
                </div>
                <div>
                    <ul>
                        <form method="POST" action="/posts/delete"><button>Delete Post</button></form>
                        <li><a href="/posts/edit/<%=post.id%>">Edit Post</a></li>
                        <li><a href="/posts/view/<%=post.id%>">View Post</a></li>
                    </ul>
                </div>
            </article>